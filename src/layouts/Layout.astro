---
import { Font } from 'astro:assets';

import '../styles/main.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Red Pixel — We solve business problems with tech solutions',
	description = 'Red Pixel is a two-person dev studio run by sisters Vivian & Daniela Guillen. We plug into your team, ship to your timeline, and become the reliable dev partner startups and agencies keep on speed-dial.',
} = Astro.props;
---

<!doctype html>
<html lang='en'>
	<head>
		<meta charset='UTF-8' />
		<meta
			name='viewport'
			content='width=device-width,initial-scale=1.0'
		/>
		<meta
			name='description'
			content={description}
		/>
		<title>{title}</title>

		<meta
			property='og:title'
			content={title}
		/>
		<meta
			property='og:description'
			content={description}
		/>
		<meta
			property='og:type'
			content='website'
		/>

		<Font
			cssVariable='--font-oswald'
			preload={[{ weight: '400' }, { weight: '700' }]}
		/>
		<Font
			cssVariable='--font-open-sans'
			preload={[{ weight: '400' }]}
		/>
		<Font cssVariable='--font-space-mono' />

		<link
			rel='icon'
			type='image/png'
			href='/img/logo-mark.png'
		/>

		<script
			defer
			src='https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js'
		></script>
	</head>
	<body>
		<a
			href='#main'
			class='sr-only rounded-full bg-brand px-4 py-2 text-white focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100]'
		>
			Skip to content
		</a>
		<slot />
	</body>
</html>
