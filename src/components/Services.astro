---
const R = '#EF4123';
const O = '#F7941E';
const G = '#f0d9d3';

const services = [
	{
		num: '01',
		title: 'E-Commerce Development',
		desc: 'Shopify and headless storefronts engineered to load fast and convert.',
		glyph: [G, R, G, R, R, R, G, R, O],
	},
	{
		num: '02',
		title: 'Web App Development',
		desc: 'Robust, maintainable apps built with Vue, React and Laravel.',
		glyph: [R, G, R, G, R, G, R, G, R],
	},
	{
		num: '03',
		title: 'Website Development',
		desc: 'Fast, accessible marketing sites with pixel-clean front-ends.',
		glyph: [R, R, R, G, O, G, R, R, R],
	},
	{
		num: '04',
		title: 'Speed Optimization',
		desc: 'Core Web Vitals tuned to green — real, measurable performance.',
		glyph: [G, G, R, G, R, G, R, O, G],
	},
];
---

<section
	id='services'
	class='bg-white pt-20 lg:pt-28'
>
	<div class='container'>
		<div
			class='flex flex-col gap-4 border-b-2 border-ink pb-5 md:flex-row md:items-end md:justify-between'
		>
			<div>
				<p class='eyebrow mb-3'>03 — What we do</p>
				<h2 class='display text-5xl text-ink sm:text-6xl'>Services</h2>
			</div>
			<p class='max-w-sm text-ink-soft md:text-right'>
				Four ways we plug in — from storefront to full app, plus the speed to back it up.
			</p>
		</div>

		<ul>
			{
				services.map((service) => (
					<li class='border-b border-hairline'>
						<div class='group grid grid-cols-[64px_1fr] items-center gap-5 py-7 pl-2 transition-all duration-200 hover:bg-[#FFF4EE] hover:pl-5 sm:grid-cols-[90px_1fr_60px] sm:gap-6'>
							<span class='display text-4xl text-brand'>{service.num}</span>
							<div>
								<h3 class='display text-2xl text-ink sm:text-3xl'>{service.title}</h3>
								<p class='mt-1.5 max-w-xl text-ink-soft'>{service.desc}</p>
							</div>
							<div
								aria-hidden='true'
								class='hidden grid-cols-3 gap-[3px] justify-self-end sm:grid'
							>
								{service.glyph.map((cell) => (
									<span
										class='h-[11px] w-[11px]'
										style={`background:${cell}`}
									/>
								))}
							</div>
						</div>
					</li>
				))
			}
		</ul>
	</div>
</section>
