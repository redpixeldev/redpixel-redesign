---
const stats = [
	{ value: '12+', label: 'Years experience' },
	{ value: '90+', label: 'Projects shipped' },
	{ value: '2', label: 'Senior devs, no handoffs' },
];
---

<section
	id='about'
	class='bg-paper py-20 lg:py-24'>
	<div class='container grid items-center gap-12 lg:grid-cols-2 lg:gap-14'>
		<div class='relative'>
			<span
				aria-hidden='true'
				class='bg-brand absolute -top-3 -left-3 z-10 h-3.5 w-3.5'
			></span>
			<span
				aria-hidden='true'
				class='bg-orange absolute -top-3 left-2 z-10 h-2 w-2'
			></span>
			<span
				aria-hidden='true'
				class='bg-orange absolute -right-3 -bottom-3 z-10 h-3.5 w-3.5'
			></span>
			<span
				aria-hidden='true'
				class='bg-brand absolute right-2 -bottom-3 z-10 h-2 w-2'
			></span>
			<div class='shadow-ink/15 overflow-hidden rounded-2xl shadow-2xl'>
				<img
					src='/img/sisters.png'
					alt='Illustrated portrait of sisters Vivian and Daniela Guillen working together at a laptop'
					width='1448'
					height='1086'
					loading='lazy'
					class='block aspect-4/3 w-full object-cover'
				/>
			</div>
		</div>

		<div>
			<p class='eyebrow mb-3'>// About us</p>
			<h2 class='display text-ink text-4xl sm:text-5xl'>
				We're Vivian <span class='text-brand'>&amp;</span> Daniela
			</h2>
			<p class='text-ink-soft mt-5 text-lg leading-relaxed'>
				Two sisters, both full-stack developers. We learn how your business works, agree on the scope up front, and ship
				to your timeline. You hear from us before you have to ask, and the work lands when we
				said it would.
			</p>
			<p class='text-ink-soft mt-4 text-lg leading-relaxed'>
				Startups and agencies keep us on retainer because we move fast and stay focused. One senior pair, start to
				finish.
			</p>

			<dl class='mt-8 flex flex-wrap gap-3'>
				{
					stats.map((stat) => (
						<div class='border-brand/10 shadow-ink/5 rounded-xl border bg-white px-5 py-3.5 shadow-sm'>
							<dt class='display text-brand text-3xl'>{stat.value}</dt>
							<dd class='text-gray mt-0.5 text-xs font-semibold'>{stat.label}</dd>
						</div>
					))
				}
			</dl>
		</div>
	</div>
</section>
