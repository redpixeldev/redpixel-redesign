---
const defaultSteps = [
	{
		num: '1',
		title: 'Define',
		desc: 'We sit down with you to understand the problem, define the scope, and agree on what success looks like.',
	},
	{
		num: '2',
		title: 'Design',
		desc: 'Clear plan, clean structure — we map the build before a line of code is written.',
	},
	{
		num: '3',
		title: 'Build',
		desc: 'Two senior devs heads-down, shipping in steady increments you can see.',
	},
	{
		num: '4',
		title: 'Ship',
		desc: 'Tested, fast, and launched on your timeline — with support after go-live.',
	},
];

interface Props {
	steps?: { num: string; title: string; desc: string }[];
}
const { steps = defaultSteps } = Astro.props;
---

<section
	id='process'
	class='border-hairline border-y bg-white py-20 lg:py-24'>
	<div class='container'>
		<div class='mx-auto max-w-xl text-center'>
			<p class='eyebrow mb-3 justify-center'>// How we work</p>
			<h2 class='display text-ink text-4xl sm:text-5xl'>A simple, honest process</h2>
			<p class='text-ink-soft mt-4 text-lg leading-relaxed'>
				No bloated agency runaround. Four clear steps from first hello to shipped.
			</p>
		</div>

		<ol class='relative mt-16 grid gap-12 sm:grid-cols-2 lg:grid-cols-4 lg:gap-6'>
			<!-- dashed connector line (desktop only) -->
			<span
				aria-hidden='true'
				class='absolute top-7 right-[12%] left-[12%] hidden h-0.5 lg:block'
				style='background:repeating-linear-gradient(90deg,#f0c9bf 0,#f0c9bf 7px,transparent 7px,transparent 14px)'
			></span>

			{
				steps.map((step) => (
					<li class='relative text-center'>
						<div class='bg-brand shadow-brand/30 relative mx-auto flex h-14 w-14 items-center justify-center shadow-lg'>
							<span class='display text-2xl text-white'>{step.num}</span>
							<span
								aria-hidden='true'
								class='bg-orange absolute -top-1.5 -right-1.5 h-2 w-2'
							/>
						</div>
						<h3 class='display text-ink mt-6 text-xl'>{step.title}</h3>
						<p class='text-ink-soft mx-auto mt-2 max-w-xs text-sm leading-relaxed'>{step.desc}</p>
					</li>
				))
			}
		</ol>
	</div>
</section>
