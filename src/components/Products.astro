---
const products = [
	{ num: 1, name: 'Sponsonizer', domain: 'sponsonizer.com', desc: 'Calendly for newsletter sponsorships' },
	{
		num: 2,
		name: 'Calculator Friend',
		domain: 'calculatorfriend.com',
		desc: 'Hundreds of instant calculators, free for educational use.',
	},
	{
		num: 3,
		name: 'Windybase',
		domain: 'windybase.com',
		desc: 'A curated collection of Tailwind CSS templates and component libraries.',
	},
	{
		num: 4,
		name: 'Design2Tailwind',
		domain: 'design2tailwind.com',
		desc: 'A productized service to convert your designs to Tailwind CSS markup.',
	},
	{
		num: 5,
		name: 'Tailwind Weekly',
		domain: 'tailwindweekly.com',
		desc: 'A weekly newsletter for Tailwind CSS developers and designers.',
	},
];

const favicon = (domain: string) => `https://www.google.com/s2/favicons?domain=${domain}&sz=128`;
---

<section
	id='products'
	class='bg-white pt-20 pb-8 lg:pt-24 lg:pb-8'>
	<div class='container'>
		<div class='flex flex-col gap-6 md:flex-row md:items-end md:justify-between'>
			<div>
				<p class='eyebrow mb-3'>// Our own</p>
				<h2 class='display text-ink text-5xl sm:text-6xl'>Products we built</h2>
			</div>
			<p class='text-ink-soft max-w-sm md:text-right'>Between client work, we build and ship our own products.</p>
		</div>

		<ul class='border-hairline mt-10 grid border-t border-l sm:grid-cols-2 lg:grid-cols-3'>
			{
				products.map((product) => (
					<li class='border-hairline border-r border-b'>
						<a
							href={`https://${product.domain}`}
							target='_blank'
							rel='noopener noreferrer'
							class='ring-brand relative flex h-full cursor-pointer flex-col p-6 transition-shadow duration-300 ring-inset hover:ring-2'>
							<span
								aria-hidden='true'
								class='display absolute top-4 right-5 text-3xl text-[#e6e6e6]'>
								0{product.num}
							</span>
							<img
								src={favicon(product.domain)}
								alt=''
								width='30'
								height='30'
								loading='lazy'
								class='h-[30px] w-[30px] rounded-md'
							/>
							<h3 class='display text-ink mt-4 text-xl'>{product.name}</h3>
							<p class='text-ink-soft mt-2 flex-1 text-sm leading-relaxed'>{product.desc}</p>
							<span class='text-brand mt-4 font-mono text-xs font-bold tracking-[0.1em] uppercase'>Visit ↗</span>
						</a>
					</li>
				))
			}
			<li class='border-hairline border-r border-b bg-[#FDECE8]'>
				<div class='flex h-full flex-col justify-center p-6'>
					<p class='display text-ink text-2xl leading-tight'>More in<br />the works</p>
					<div
						aria-hidden='true'
						class='mt-3 flex gap-1'>
						<span class='bg-brand h-2.5 w-2.5'></span>
						<span class='bg-orange h-2.5 w-2.5'></span>
						<span class='bg-brand h-2.5 w-2.5'></span>
					</div>
				</div>
			</li>
		</ul>
	</div>
</section>
