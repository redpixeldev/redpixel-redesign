---
// Set `image` to a file in /public to use your own screenshot (e.g. '/sponsonizer.png').
// Leave it off and the card falls back to a live screenshot via image.thum.io.
const defaultProjects = [
	{ name: 'Sponsonizer', domain: 'sponsonizer.com', image: '/sponsonizer.png', desc: 'Sponsorship matchmaking that pairs creators with the right brands.', sub: 'Sponsorship matchmaking', tags: ['Web App', 'Vue'] },
	{ name: 'Calculator Friend', domain: 'calculatorfriend.com', image: '/sponsonizer.png', desc: 'A friendly library of smart calculators for everyday math.', sub: 'Everyday calculators', tags: ['Tool', 'SEO'] },
	{ name: 'Windybase', domain: 'windybase.com', image: '/sponsonizer.png', desc: 'No-code databases that small teams actually enjoy using.', sub: 'No-code databases', tags: ['SaaS', 'Laravel'] },
	{ name: 'Design2Tailwind', domain: 'design2tailwind.com', image: '/sponsonizer.png', desc: 'Turn any design into clean, production-ready Tailwind.', sub: 'Design-to-code tool', tags: ['Dev Tool'] },
	{ name: 'Red Pixel Themes', domain: 'redpixelthemes.com', image: '/sponsonizer.png', desc: 'Premium Tailwind UI themes and components for builders.', sub: 'Premium web themes', tags: ['Themes', 'Shop'] },
	{ name: 'Red Pixel', domain: 'redpixel.io', image: '/sponsonizer.png', desc: 'Our studio home — where every project starts.', sub: 'Web design studio', tags: ['Studio'] },
];

interface Project {
	name: string;
	domain: string;
	image?: string;
	desc?: string;
	sub?: string;
	tags?: string[];
}
interface Props {
	id?: string;
	eyebrow?: string;
	title?: string;
	intro?: string;
	columns?: 3 | 4;
	compact?: boolean;
	projects?: Project[];
}
const {
	id = 'work',
	eyebrow = '// Latest jobs',
	title = 'Recent client work',
	intro = 'Real projects with real results. Visit any project to see it in action.',
	columns = 3,
	compact = false,
	projects = defaultProjects,
} = Astro.props;

const shot = (domain: string) => `https://image.thum.io/get/width/900/crop/900/https://${domain}`;
const fallback =
	"this.onerror=null;this.src='data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22900%22 height=%22675%22><rect width=%22100%25%22 height=%22100%25%22 fill=%22%23f7f7f7%22/></svg>'";

const gridCols = columns === 4 ? 'lg:grid-cols-4' : 'lg:grid-cols-3';
---

<section
	id={id}
	class='bg-paper py-20 lg:py-24'>
	<div class='container'>
		<div class='flex flex-col gap-6 md:flex-row md:items-end md:justify-between'>
			<div>
				<p class='eyebrow mb-3'>{eyebrow}</p>
				<h2 class='display text-ink text-5xl sm:text-6xl'>{title}</h2>
			</div>
			{intro && <p class='text-ink-soft max-w-sm md:text-right'>{intro}</p>}
		</div>

		<ul class={`mt-11 grid gap-6 sm:grid-cols-2 ${gridCols}`}>
			{
				projects.map((project) => (
					<li>
						<a
							href={`https://${project.domain}`}
							target='_blank'
							rel='noopener noreferrer'
							class='group relative flex h-full flex-col border border-hairline bg-white shadow-md shadow-ink/15 transition-all duration-200 hover:-translate-y-1.5 hover:shadow-lg hover:shadow-brand/40'
						>
							<div class='aspect-[4/3] overflow-hidden border-b border-hairline bg-paper'>
								<img
									src={project.image ?? shot(project.domain)}
									alt={`Screenshot of the ${project.name} website`}
									width='900'
									height='675'
									loading='lazy'
									onerror={fallback}
									class='h-full w-full object-cover object-top'
								/>
							</div>
							{compact ? (
								<div class='p-5'>
									<div class='flex items-center justify-between gap-2'>
										<h3 class='display text-ink text-lg'>{project.name}</h3>
										<span class='text-brand font-mono text-xs font-bold'>View ↗</span>
									</div>
									<p class='text-gray mt-1 truncate text-sm'>{project.sub ?? project.desc}</p>
								</div>
							) : (
								<div class='flex flex-1 flex-col p-5'>
									<div class='flex items-center justify-between gap-2'>
										<h3 class='display text-ink text-xl'>{project.name}</h3>
										<span class='text-brand text-sm font-bold'>View site ↗</span>
									</div>
									<p class='text-ink-soft mt-2 flex-1 text-sm leading-relaxed'>{project.desc}</p>
									{project.tags && (
										<div class='mt-3 flex flex-wrap gap-1.5'>
											{project.tags.map((tag) => (
												<span class='border-hairline bg-paper text-gray border px-2.5 py-1 font-mono text-[11px] tracking-wide'>
													{tag}
												</span>
											))}
										</div>
									)}
								</div>
							)}
						</a>
					</li>
				))
			}
		</ul>
	</div>
</section>
