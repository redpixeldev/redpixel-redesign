---
// Live site screenshots render via image.thum.io so cards are never empty.
const projects = [
	{ name: 'Sponsonizer', domain: 'sponsonizer.com', desc: 'Sponsorship matchmaking that pairs creators with the right brands.', tags: ['Web App', 'Vue'] },
	{ name: 'Calculator Friend', domain: 'calculatorfriend.com', desc: 'A friendly library of smart calculators for everyday math.', tags: ['Tool', 'SEO'] },
	{ name: 'Windybase', domain: 'windybase.com', desc: 'No-code databases that small teams actually enjoy using.', tags: ['SaaS', 'Laravel'] },
	{ name: 'Design2Tailwind', domain: 'design2tailwind.com', desc: 'Turn any design into clean, production-ready Tailwind.', tags: ['Dev Tool'] },
	{ name: 'Red Pixel Themes', domain: 'redpixelthemes.com', desc: 'Premium Tailwind UI themes and components for builders.', tags: ['Themes', 'Shop'] },
	{ name: 'Red Pixel', domain: 'redpixel.io', desc: 'Our studio home — where every project starts.', tags: ['Studio'] },
];

const shot = (domain: string) => `https://image.thum.io/get/width/900/crop/675/https://${domain}`;
const fallback =
	"this.onerror=null;this.src='data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22900%22 height=%22675%22><rect width=%22100%25%22 height=%22100%25%22 fill=%22%23f7f7f7%22/></svg>'";
---

<section
	id='work'
	class='bg-paper py-20 lg:py-28'
>
	<div class='container'>
		<div class='flex flex-col gap-6 md:flex-row md:items-end md:justify-between'>
			<div>
				<p class='eyebrow mb-3'>// Latest jobs</p>
				<h2 class='display text-5xl text-ink sm:text-6xl'>Recent client work</h2>
			</div>
			<p class='max-w-sm text-ink-soft md:text-right'>
				Real builds, real results. Hover any project for a closer look.
			</p>
		</div>

		<ul class='mt-11 grid gap-6 sm:grid-cols-2 lg:grid-cols-3'>
			{
				projects.map((project) => (
					<li>
						<a
							href={`https://${project.domain}`}
							target='_blank'
							rel='noopener noreferrer'
							class='group relative flex h-full flex-col border border-hairline bg-white shadow-md shadow-ink/15 transition-all duration-200 hover:-translate-y-1.5 hover:shadow-lg hover:shadow-brand/40'
						>
							<span
								aria-hidden='true'
								class='absolute left-3 top-3 z-10 h-2.5 w-2.5 bg-brand'
							/>
							<div class='aspect-[4/3] overflow-hidden border-b border-hairline bg-paper'>
								<img
									src={shot(project.domain)}
									alt={`Screenshot of the ${project.name} website`}
									width='900'
									height='675'
									loading='lazy'
									onerror={fallback}
									class='h-full w-full object-cover object-top'
								/>
							</div>
							<div class='flex flex-1 flex-col p-5'>
								<div class='flex items-center justify-between gap-2'>
									<h3 class='display text-xl text-ink'>{project.name}</h3>
									<span class='text-sm font-bold text-brand'>View site ↗</span>
								</div>
								<p class='mt-2 flex-1 text-sm leading-relaxed text-ink-soft'>{project.desc}</p>
								<div class='mt-3 flex flex-wrap gap-1.5'>
									{project.tags.map((tag) => (
										<span class='border border-hairline bg-paper px-2.5 py-1 font-mono text-[11px] tracking-wide text-gray'>
											{tag}
										</span>
									))}
								</div>
							</div>
						</a>
					</li>
				))
			}
		</ul>
	</div>
</section>
