---
// Set `image` to a file in /public to use your own screenshot (e.g. '/sponsonizer.png').
// Leave it off and the card falls back to a live screenshot via image.thum.io.
const defaultProjects = [
	{
		name: 'Cornelia Hernandez',
		domain: 'corneliahernandez.com',
		image: '/cornelia.png',
		desc: 'Personal site for Dr. Cornelia Hernandez: sex therapy, couples counseling, books, and a podcast on intimacy.',
		sub: 'Therapist & author',
		tags: ['Personal', 'Book Author'],
	},
	{
		name: 'Baselair',
		domain: 'baselair.com',
		image: '/baselair.png',
		desc: 'A community platform where miniature painters share projects, find inspiration, and connect with fellow hobbyists.',
		sub: 'Community for miniature painters',
		tags: ['Community', 'Web App'],
	},
	{
		name: 'Source',
		domain: 'trysource.com',
		image: '/trysource.png',
		desc: 'Chocolate supplements brand: delicious vegan, gluten-free, non-GMO treats for wellness and self-care.',
		sub: 'Chocolate supplements',
		tags: ['eCommerce', 'Shopify'],
	},
	{
		name: 'Integridad y Sabiduria',
		domain: 'integridadysabiduria.org',
		image: '/integridadysabiduria.png',
		desc: 'Spanish-language Christian ministry sharing sermons, articles, and Bible studies to help people grow in their faith.',
		sub: 'Christian ministry',
		tags: ['Nonprofit', 'Church'],
	},
	{
		name: 'Boostrap Logos',
		domain: 'boostraplogos.com',
		image: '/boostrap-logos.png',
		desc: 'A curated gallery of clean, modern logos to inspire founders branding their next project.',
		sub: 'Logo marketplace',
		tags: ['Logo Marketplace', 'Web App'],
	},
	{
		name: 'Fairplay Policy',
		domain: 'fairplaypolicy.org',
		image: '/fairplay-policy.png',
		desc: 'Nonprofit foundation advancing “care justice”: grants and programs that make invisible domestic labor visible and equitable.',
		sub: 'Care-justice foundation',
		tags: ['Nonprofit', 'Grants'],
	},
	{
		name: 'Siptequila',
		domain: 'siptequila.com',
		image: '/siptequila.png',
		desc: 'E-commerce store delivering premium tequila and agave spirits, plus a curated monthly bottle subscription.',
		sub: 'Premium tequila shop',
		tags: ['eCommerce', 'Shopify'],
	},
	{
		name: 'Accessability Officer',
		domain: 'accessabilityofficer.com',
		image: '/accessability-officer.png',
		desc: 'Full-service digital accessibility for government agencies: audits by disabled testers, training, and ADA/WCAG compliance.',
		sub: 'Accessibility compliance',
		tags: ['B2B', 'Accessibility'],
	},
	{
		name: 'Swiftwick',
		domain: 'swiftwick.com',
		image: '/swiftwick.png',
		desc: 'E-commerce brand for performance socks engineered for running, cycling, hiking, and golf, proudly made in the USA.',
		sub: 'Performance sock brand',
		tags: ['eCommerce', 'Shopify'],
	},
];

interface Project {
	name: string;
	domain: string;
	image?: string;
	desc?: string;
	sub?: string;
	tags?: string[];
}
interface Props {
	id?: string;
	eyebrow?: string;
	title?: string;
	intro?: string;
	columns?: 3 | 4;
	compact?: boolean;
	projects?: Project[];
}
const {
	id = 'work',
	eyebrow = '// Latest jobs',
	title = 'Recent client work',
	intro = 'Sites we built and shipped for clients. Click any one to see it live.',
	columns = 3,
	compact = false,
	projects = defaultProjects,
} = Astro.props;

const shot = (domain: string) => `https://image.thum.io/get/width/900/crop/900/https://${domain}`;
const fallback =
	"this.onerror=null;this.src='data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22900%22 height=%22675%22><rect width=%22100%25%22 height=%22100%25%22 fill=%22%23f7f7f7%22/></svg>'";

const gridCols = columns === 4 ? 'lg:grid-cols-4' : 'lg:grid-cols-3';
---

<section
	id={id}
	class='bg-paper py-20 lg:py-24'>
	<div class='container'>
		<div class='flex flex-col gap-6 md:flex-row md:items-end md:justify-between'>
			<div>
				<p class='eyebrow mb-3'>{eyebrow}</p>
				<h2 class='display text-ink text-5xl sm:text-6xl'>{title}</h2>
			</div>
			{intro && <p class='text-ink-soft max-w-sm md:text-right'>{intro}</p>}
		</div>

		<ul class={`mt-11 grid gap-6 sm:grid-cols-2 ${gridCols}`}>
			{
				projects.map((project) => (
					<li>
						<a
							href={`https://${project.domain}`}
							target='_blank'
							rel='noopener noreferrer'
							class='group border-hairline shadow-ink/15 hover:shadow-brand/40 relative flex h-full flex-col border bg-white shadow-md transition-all duration-200 hover:-translate-y-1.5 hover:shadow-lg'>
							<div class='border-hairline bg-paper aspect-[4/3] overflow-hidden border-b'>
								<img
									src={project.image ?? shot(project.domain)}
									alt={`Screenshot of the ${project.name} website`}
									width='900'
									height='675'
									loading='lazy'
									onerror={fallback}
									class='h-full w-full object-cover object-top'
								/>
							</div>
							{compact ? (
								<div class='p-5'>
									<div class='flex items-center justify-between gap-2'>
										<h3 class='display text-ink text-lg'>{project.name}</h3>
										<span class='text-brand font-mono text-xs font-bold shrink-0'>View ↗</span>
									</div>
									<p class='text-gray mt-1 truncate text-sm'>{project.sub ?? project.desc}</p>
								</div>
							) : (
								<div class='flex flex-1 flex-col p-5'>
									<div class='flex items-center justify-between gap-2'>
										<h3 class='display text-ink text-xl'>{project.name}</h3>
										<span class='text-brand text-sm font-bold'>View site ↗</span>
									</div>
									<p class='text-ink-soft mt-2 flex-1 text-sm leading-relaxed'>{project.desc}</p>
									{project.tags && (
										<div class='mt-3 flex flex-wrap gap-1.5'>
											{project.tags.map((tag) => (
												<span class='border-hairline bg-paper text-gray border px-2.5 py-1 font-mono text-[11px] tracking-wide'>
													{tag}
												</span>
											))}
										</div>
									)}
								</div>
							)}
						</a>
					</li>
				))
			}
		</ul>
	</div>
</section>
