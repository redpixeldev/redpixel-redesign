---
const navLinks = [
	{ label: 'Home', href: '#top' },
	{ label: 'About', href: '#about' },
	{ label: 'Services', href: '#services' },
	{ label: 'Process', href: '#process' },
	{ label: 'Work', href: '#work' },
	{ label: 'Products', href: '#products' },
	{ label: 'Contact', href: '#contact' },
];

const email = 'vivian@redpixel.io';
const year = new Date().getFullYear();
---

<footer class='border-t border-hairline bg-white'>
	<div class='container py-12'>
		<div class='flex flex-col gap-10 md:flex-row md:items-center md:justify-between'>
			<a
				href='#top'
				aria-label='Red Pixel — home'
			>
				<img
					src='/img/logo.png'
					alt='Red Pixel'
					class='h-12 w-auto'
				/>
			</a>

			<nav aria-label='Footer'>
				<ul class='flex flex-wrap gap-x-7 gap-y-2'>
					{
						navLinks.map((link) => (
							<li>
								<a
									href={link.href}
									class='text-sm font-semibold text-ink-soft transition-colors hover:text-brand'
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>

			<div class='flex items-center gap-5 text-sm'>
				<a
					href={`mailto:${email}`}
					class='font-bold text-ink transition-colors hover:text-brand'
				>
					{email}
				</a>
			</div>
		</div>
	</div>

	<div class='border-t border-hairline py-5 text-center text-sm text-gray'>
		&copy; {year} Red Pixel · Web Design &amp; Development
	</div>
</footer>
