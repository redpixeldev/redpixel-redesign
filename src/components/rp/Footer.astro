---
const navLinks = [
	{ label: 'Home', href: '/#top' },
	{ label: 'About', href: '/#about' },
	{ label: 'Services', href: '/#services' },
	{ label: 'Process', href: '/#process' },
	{ label: 'Work', href: '/#work' },
	{ label: 'Products', href: '/#products' },
	{ label: 'Contact', href: '/#contact' },
];

const email = 'hello@redpixel.io';
const year = new Date().getFullYear();
---

<footer class='border-hairline border-t bg-white'>
	<div class='container py-12'>
		<div class='flex flex-col gap-10 md:flex-row md:items-center md:justify-between'>
			<a
				href='/'
				aria-label='Red Pixel — home'>
				<img
					src='/img/logo.png'
					alt='Red Pixel'
					class='h-12 w-auto'
				/>
			</a>

			<nav aria-label='Footer'>
				<ul class='flex flex-wrap gap-x-7 gap-y-2'>
					{
						navLinks.map((link) => (
							<li>
								<a
									href={link.href}
									class='text-ink-soft hover:text-brand text-sm font-semibold transition-colors'>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>

			<div class='flex items-center gap-5 text-sm'>
				<a
					href={`mailto:${email}`}
					class='text-ink-soft hover:text-brand font-bold transition-colors'>
					<svg
						xmlns='http://www.w3.org/2000/svg'
						fill='none'
						viewBox='0 0 24 24'
						stroke-width='1.5'
						stroke='currentColor'
						class='size-5'>
						<path
							stroke-linecap='round'
							stroke-linejoin='round'
							d='M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75'
						></path>
					</svg>
				</a>
			</div>
		</div>
	</div>

	<div class='border-hairline text-gray border-t py-5 text-center text-sm'>
		&copy; {year} Red Pixel · Web Design &amp; Development
	</div>
</footer>
