---
// Real enquiry form — posts to vivian@redpixel.io via FormSubmit (works on static hosting).
const formAction = 'https://formsubmit.co/vivian@redpixel.io';
---

<section
	id='contact'
	class='bg-white py-20 lg:py-24'
>
	<div class='container max-w-5xl'>
		<div class='relative overflow-hidden rounded-3xl bg-brand px-6 py-12 sm:px-12 sm:py-14'>
			<!-- pixel decoration, top-right -->
			<div
				aria-hidden='true'
				class='absolute right-6 top-6 grid grid-cols-4 gap-1.5 opacity-60'
			>
				<span class='h-3 w-3 bg-white/90'></span>
				<span class='h-3 w-3 bg-white/40'></span>
				<span></span>
				<span class='h-3 w-3 bg-white/70'></span>
				<span class='h-3 w-3 bg-white/30'></span>
				<span class='h-3 w-3 bg-white/60'></span>
				<span></span>
				<span class='h-3 w-3 bg-white/50'></span>
			</div>

			<div class='relative grid items-center gap-10 lg:grid-cols-2 lg:gap-12'>
				<div>
					<h2 class='display text-4xl text-white sm:text-5xl'>
						Ready to let us run your website?
					</h2>
					<p class='mt-4 max-w-md text-lg leading-relaxed text-white/90'>
						Tell us a little about your business and we'll take it from there. You run the shop, we handle the rest.
					</p>
					<p class='mt-4 font-mono uppercase text-sm text-white'>From $99/mo · $0 setup · Cancel anytime</p>
				</div>

				<form
					action={formAction}
					method='POST'
					class='flex flex-col gap-4 rounded-2xl bg-white p-6 sm:p-7'
				>
					<input
						type='hidden'
						name='_subject'
						value='New Red Pixel website enquiry'
					/>
					<input
						type='hidden'
						name='_template'
						value='table'
					/>
					<div>
						<label
							for='rp-name'
							class='mb-1.5 block font-mono uppercase text-[11px] tracking-wider text-ink font-semibold'>Your name</label>
						<input
							id='rp-name'
							name='name'
							required
							placeholder='Jane Smith'
							class='w-full rounded-lg border border-hairline px-3.5 py-3 text-[15px] text-ink focus:border-brand focus:ring-0'
						/>
					</div>
					<div>
						<label
							for='rp-biz'
							class='mb-1.5 block font-mono uppercase text-[11px] tracking-wider text-ink font-semibold'>Business name</label>
						<input
							id='rp-biz'
							name='business'
							required
							placeholder="Jane's Bakery"
							class='w-full rounded-lg border border-hairline px-3.5 py-3 text-[15px] text-ink focus:border-brand focus:ring-0'
						/>
					</div>
					<div>
						<label
							for='rp-email'
							class='mb-1.5 block font-mono uppercase text-[11px] tracking-wider text-ink font-semibold'>Email</label>
						<input
							id='rp-email'
							name='email'
							type='email'
							required
							placeholder='jane@email.com'
							class='w-full rounded-lg border border-hairline px-3.5 py-3 text-[15px] text-ink focus:border-brand focus:ring-0'
						/>
					</div>
					<div>
						<label
							for='rp-msg'
							class='mb-1.5 block font-mono uppercase text-[11px] tracking-wider text-ink font-semibold'>
							Message <span class='normal-case text-gray-light'>(optional)</span>
						</label>
						<textarea
							id='rp-msg'
							name='message'
							rows='2'
							placeholder='Tell us about your business…'
							class='w-full resize-y rounded-lg border border-hairline px-3.5 py-3 text-[15px] text-ink focus:border-brand focus:ring-0'
						></textarea>
					</div>
					<button
						type='submit'
						class='btn-primary mt-1 w-full'
					>
						Get my website
					</button>
				</form>
			</div>
		</div>
	</div>
</section>
