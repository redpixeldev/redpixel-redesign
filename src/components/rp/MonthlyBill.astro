---
const chips = [
	{ label: 'From $99/mo', color: 'var(--color-brand)' },
	{ label: '$0 setup', color: 'var(--color-orange)' },
	{ label: 'Cancel anytime', color: 'var(--color-brand)' },
];

const honesty = [
	'While you’re subscribed, we keep your website and domain hosted, secure, and up to date.',
	'No big upfront cost. One flat monthly price, the same rate every month.',
	'No contract, no lock-in. Cancel anytime, with no penalties.',
	'You’re paying for an all-in, done-for-you website, not a one-time build.',
];
---

<section
	id='pricing'
	class='bg-paper py-20 lg:py-24'>
	<div class='container grid items-center gap-12 lg:grid-cols-2 lg:gap-14'>
		<div>
			<p class='eyebrow mb-3'>// The deal in plain English</p>
			<h2 class='display text-ink text-4xl sm:text-5xl'>
				One monthly bill. We handle the rest, for as long as you want it.
			</h2>
			<p class='text-ink-soft mt-5 text-lg leading-relaxed'>
				Small-business websites start at <strong class='text-ink font-bold'>$99 a month, with no setup fee.</strong>{
					' '
				}
				Bigger, more complex sites may carry a one-time setup fee. We scope it before anything starts, so nothing surprises
				you.
			</p>
			<ul class='mt-6 flex flex-wrap gap-2.5'>
				{
					chips.map((chip) => (
						<li class='text-ink inline-flex items-center gap-2 border border-[#f6dcc9] bg-white px-3.5 py-2 font-mono text-xs font-bold'>
							<span
								aria-hidden='true'
								class='inline-block h-1.5 w-1.5'
								style={`background:${chip.color}`}
							/>
							{chip.label}
						</li>
					))
				}
			</ul>
		</div>

		<ul class='flex flex-col gap-3.5'>
			{
				honesty.map((item) => (
					<li class='shadow-ink/5 flex gap-3.5 rounded-2xl bg-white p-5 shadow-md'>
						<span
							aria-hidden='true'
							class='bg-brand flex h-7 w-7 flex-none items-center justify-center rounded-lg text-sm font-bold text-white'>
							✓
						</span>
						<p class='text-ink text-[15px] leading-relaxed'>{item}</p>
					</li>
				))
			}
		</ul>
	</div>
</section>
