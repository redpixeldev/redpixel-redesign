---
// All brand logos from a single library — Simple Icons (simpleicons.org, CC0).
// Inlined as SVG so they're self-hosted (no CDN) and colored with each brand hex.
import tailwindcss from 'simple-icons/icons/tailwindcss.svg?raw';
import vuedotjs from 'simple-icons/icons/vuedotjs.svg?raw';
import nuxt from 'simple-icons/icons/nuxt.svg?raw';
import alpinedotjs from 'simple-icons/icons/alpinedotjs.svg?raw';
import react from 'simple-icons/icons/react.svg?raw';
import laravel from 'simple-icons/icons/laravel.svg?raw';
import shopify from 'simple-icons/icons/shopify.svg?raw';
import wordpress from 'simple-icons/icons/wordpress.svg?raw';
import statamic from 'simple-icons/icons/statamic.svg?raw';

const stack = [
	{ name: 'Tailwind CSS', color: '#06B6D4', svg: tailwindcss },
	{ name: 'Vue.js', color: '#4FC08D', svg: vuedotjs },
	{ name: 'React', color: '#61DAFB', svg: react },
	{ name: 'Alpine.js', color: '#8BC0D0', svg: alpinedotjs },
	{ name: 'Nuxt.js', color: '#00DC82', svg: nuxt },
	{ name: 'Laravel', color: '#FF2D20', svg: laravel },
	{ name: 'Shopify', color: '#7AB55C', svg: shopify },
	{ name: 'WordPress', color: '#21759B', svg: wordpress },
	{ name: 'Statamic', color: '#FF269E', svg: statamic },
];
---

<section class='bg-white pt-10 pb-20 lg:pb-24'>
	<div class='container'>
		<p class='text-gray mb-4 font-mono text-xs tracking-[0.16em] uppercase'>Our stack</p>
		<ul class='flex flex-wrap gap-2.5'>
			{
				stack.map((tech) => (
					<li class='border-hairline text-ink-soft inline-flex items-center gap-2.5 border bg-white px-4 py-2.5 text-sm font-semibold'>
						<span
							aria-hidden='true'
							class='inline-flex h-[18px] w-[18px] [&>svg]:h-full [&>svg]:w-full'
							style={`fill:${tech.color}`}
							set:html={tech.svg}
						/>
						{tech.name}
					</li>
				))
			}
		</ul>
	</div>
</section>
