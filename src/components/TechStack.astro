---
// Real brand logos from Remix Icon (remixicon.com), inlined as SVG so they're
// self-hosted and colorable. Remix only ships 4 of our 9 brands — the rest fall
// back to a brand-colored square until we have proper marks.
import tailwindIcon from 'remixicon/icons/Logos/tailwind-css-fill.svg?raw';
import vueIcon from 'remixicon/icons/Logos/vuejs-fill.svg?raw';
import reactIcon from 'remixicon/icons/Logos/reactjs-fill.svg?raw';
import wordpressIcon from 'remixicon/icons/Logos/wordpress-fill.svg?raw';

const stack = [
	{ name: 'Tailwind CSS', color: '#38bdf8', svg: tailwindIcon },
	{ name: 'Vue.js', color: '#42b883', svg: vueIcon },
	{ name: 'Nuxt.js', color: '#00dc82', svg: null },
	{ name: 'Alpine.js', color: '#77c1d2', svg: null },
	{ name: 'React', color: '#61dafb', svg: reactIcon },
	{ name: 'Laravel', color: '#ff2d20', svg: null },
	{ name: 'Shopify', color: '#95bf47', svg: null },
	{ name: 'WordPress', color: '#21759b', svg: wordpressIcon },
	{ name: 'Statamic', color: '#ff269e', svg: null },
];
---

<section class='bg-white pb-20 pt-10 lg:pb-28'>
	<div class='container'>
		<p class='mb-4 font-mono text-xs uppercase tracking-[0.16em] text-gray'>Our stack</p>
		<ul class='flex flex-wrap gap-2.5'>
			{
				stack.map((tech) => (
					<li class='inline-flex items-center gap-2.5 border border-hairline bg-white px-4 py-2.5 text-sm font-semibold text-ink-soft'>
						{tech.svg ? (
							<span
								aria-hidden='true'
								class='inline-flex h-[18px] w-[18px] [&>svg]:h-full [&>svg]:w-full'
								style={`color:${tech.color}`}
								set:html={tech.svg}
							/>
						) : (
							<span
								aria-hidden='true'
								class='inline-block h-[14px] w-[14px]'
								style={`background:${tech.color}`}
							/>
						)}
						{tech.name}
					</li>
				))
			}
		</ul>
	</div>
</section>
