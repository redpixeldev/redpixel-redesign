---
const email = 'vivian@redpixel.io';
---

<section
	id='top'
	class='bg-paper relative overflow-hidden pt-32 pb-20 lg:pt-44 lg:pb-24'>
	<!-- pixel-particle field -->
	<canvas
		id='plans-particles'
		aria-hidden='true'
		class='pointer-events-none absolute inset-0 z-0 h-full w-full'>
	</canvas>
	<!-- warm orange glow, top-right -->
	<div
		aria-hidden='true'
		class='pointer-events-none absolute -top-32 -right-32 h-[460px] w-[460px] rounded-full'
		style='background:radial-gradient(circle, rgba(247,148,30,0.16), transparent 70%)'>
	</div>

	<div class='relative z-[1] container mx-auto max-w-5xl text-center'>
		<p
			class='border-brand/20 text-brand shadow-ink/5 mb-6 inline-flex items-center gap-2.5 rounded-full border bg-white px-3.5 py-2 font-mono text-xs font-bold tracking-[0.16em] uppercase shadow-sm'>
			<span class='rp-blink-dot bg-brand inline-block h-1.5 w-1.5'></span>
			Websites, done for you
		</p>

		<h1 class='display text-ink text-5xl sm:text-6xl lg:text-7xl'>
			You run your business.<br />
			<span class='from-brand-bright to-orange bg-gradient-to-r bg-clip-text text-transparent'>
				We run your website.
			</span>
		</h1>

		<p class='text-ink-soft mx-auto mt-6 max-w-xl text-lg leading-relaxed'>
			No hosting to set up, no domains to renew, no plugins to update. We design, build, and run the whole website for
			you, from $99 a month. No setup fee, cancel anytime.
		</p>

		<div class='mt-8 flex flex-wrap items-center justify-center gap-4'>
			<a
				href={`mailto:${email}?subject=Project%20inquiry`}
				class='btn-primary'>
				Get my website
				<span aria-hidden='true'>→</span>
			</a>
			<a
				href='#pricing'
				class='btn-outline'>
				See pricing
			</a>
		</div>
	</div>
</section>

<script>
	const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
	const canvas = document.getElementById('plans-particles') as HTMLCanvasElement | null;

	if (canvas && !reduce) {
		const ctx = canvas.getContext('2d')!;
		const colors = ['#EF4123', '#F7941E', '#EE1B23'];
		const dpr = Math.min(window.devicePixelRatio || 1, 2);
		let parts: { x: number; y: number; s: number; vy: number; vx: number; a: number; c: string }[] = [];

		const resize = () => {
			const r = canvas.getBoundingClientRect();
			canvas.width = r.width * dpr;
			canvas.height = r.height * dpr;
			const count = Math.round(Math.min(60, r.width / 22));
			parts = Array.from({ length: count }, () => ({
				x: Math.random() * r.width,
				y: Math.random() * r.height,
				s: 3 + Math.random() * 6,
				vy: 0.15 + Math.random() * 0.45,
				vx: (Math.random() - 0.5) * 0.25,
				a: 0.16 + Math.random() * 0.42,
				c: colors[(Math.random() * colors.length) | 0],
			}));
		};
		resize();
		window.addEventListener('resize', resize);

		const tick = () => {
			const r = canvas.getBoundingClientRect();
			ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
			ctx.clearRect(0, 0, r.width, r.height);
			for (const p of parts) {
				p.y -= p.vy;
				p.x += p.vx;
				if (p.y < -10) {
					p.y = r.height + 10;
					p.x = Math.random() * r.width;
				}
				if (p.x < -10) p.x = r.width + 10;
				if (p.x > r.width + 10) p.x = -10;
				ctx.globalAlpha = p.a;
				ctx.fillStyle = p.c;
				ctx.fillRect(p.x, p.y, p.s, p.s);
			}
			ctx.globalAlpha = 1;
			requestAnimationFrame(tick);
		};
		tick();
	}
</script>
