import Testimonials from '@components/Testimonials.astro';
import Products from '@components/Products.astro';
import CTA from '@components/CTA.astro';
import Footer from '@components/Footer.astro';
---

<Layout>
	<Header />
	<main id='main'>
		<Hero />
		<About />
		<Services />
		<TechStack />
		<Work />
		<Testimonials />
		<Products />
		<CTA />
	</main>
	<Footer />
