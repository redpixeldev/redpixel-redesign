---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import GetWebsiteHero from '@components/GetWebsiteHero.astro';
import MonthlyBill from '@components/MonthlyBill.astro';
import Included from '@components/Included.astro';
import Process from '@components/Process.astro';
import Work from '@components/Work.astro';
import Testimonials from '@components/Testimonials.astro';
import FAQ from '@components/FAQ.astro';
import ReadyCTA from '@components/ReadyCTA.astro';
import CTA from '@components/CTA.astro';
import Footer from '@components/Footer.astro';

// Plans process ends in ongoing Maintenance (vs the homepage's one-off "Ship").
const planSteps = [
	{
		num: '1',
		title: 'Define',
		desc: 'We learn how your business works and agree on what success looks like.',
	},
	{
		num: '2',
		title: 'Design',
		desc: 'We map out every page before we start building.',
	},
	{ num: '3', title: 'Build', desc: 'We build your site in clear stages, so you can watch it come together.' },
	{
		num: '4',
		title: 'Maintenance',
		desc: 'Once you’re live, we keep it running with updates, fixes, and changes whenever you need them.',
	},
];

// Websites shown on this page's "Our work" section — replace with real managed sites.
// Add an `image: '/name.png'` (file in /public) to use your own screenshot; otherwise a live screenshot is used.
const managedProjects = [
	{
		name: 'Castalia',
		domain: 'castalia.com',
		image: '/aguacastalia.png',
		desc: 'Leadership coaching and consulting that helps executives and teams grow through creative risk-taking.',
		sub: 'Leadership coaching & consulting',
		tags: ['Consulting', 'Coaching'],
	},
	{
		name: 'Farmacia VDG',
		domain: 'farmaciavdg.com',
		image: '/farmaciavdg.png',
		desc: 'Neighborhood pharmacy serving its community with medicines, health products, and friendly local service.',
		sub: 'Neighborhood pharmacy',
		tags: ['Pharmacy', 'Local'],
	},
	{
		name: 'Antojitos',
		domain: 'antojitosscg.com',
		image: '/antojitos.png',
		desc: 'Authentic Mexican eatery serving traditional antojitos and homestyle favorites made fresh daily.',
		sub: 'Authentic Mexican food',
		tags: ['Restaurant', 'Food'],
	},
	{
		name: 'Madrigal',
		domain: 'madrigal.com',
		image: '/madrigal.png',
		desc: 'Real estate company helping clients find, buy, and sell properties with confidence.',
		sub: 'Short tagline goes here',
		tags: ['Real Estate'],
	},
];
---

<Layout
	title='Red Pixel — A professional website for your business, without the headache'
	description='Red Pixel designs, builds, hosts, and manages your whole website for one simple monthly price. From $99/mo, $0 setup, cancel anytime.'>
	<div
		aria-hidden='true'
		class='fixed inset-x-0 top-0 z-60 h-1'
		style='background:linear-gradient(90deg,#EF4123,#F7941E)'>
	</div>
	<Header />
	<main id='main'>
		<GetWebsiteHero />
		<MonthlyBill />
		<Included />
		<Process steps={planSteps} />
		<Work
			id='work'
			eyebrow='// Our work'
			title='Real websites we manage'
			intro=''
			columns={3}
			compact={true}
			projects={managedProjects}
		/>
		<Testimonials />
		<FAQ />
		<ReadyCTA />
	</main>
	<Footer />
</Layout>
