---
import NopeLayout from '@layouts/NopeLayout.astro';
import Mark from '@components/nope/Mark.astro';
import Kbd from '@components/nope/Kbd.astro';
import BrowserFeed from '@components/nope/BrowserFeed.astro';

const STORE_URL = 'https://chromewebstore.google.com/detail/nope/kndmdfldjiibneeihdfeiijghdinbhfi';
const COFFEE_URL = 'https://buymeacoffee.com/vivgui';

const features = [
	{
		name: 'One-click dismiss',
		desc: 'Click the X on any thumbnail and the video is gone — using YouTube’s own “Not interested” action. Works on Home, Subscriptions, and channel Videos tabs.',
		path: 'M15.042 21.672 13.684 16.6m0 0-2.51 2.225.569-9.47 5.227 7.917-3.286-.672ZM12 2.25V4.5m5.834.166-1.591 1.591M20.25 10.5H18M7.757 14.743l-1.59 1.59M6 10.5H3.75m4.007-4.243-1.59-1.59',
	},
	{
		name: 'Keyboard shortcut',
		desc: 'Hover a video and press your key combo to dismiss it without reaching for the mouse. Configurable in the popup. Optional.',
		path: 'm6.75 7.5 3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0 0 21 18V6a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 6v12a2.25 2.25 0 0 0 2.25 2.25Z',
	},
	{
		name: 'Suppress channel',
		desc: 'An opt-in second button that triggers YouTube’s native “Don’t recommend channel.” Off by default, and it asks for a confirming second click.',
		path: 'M18.364 18.364A9 9 0 0 0 5.636 5.636m12.728 12.728A9 9 0 0 1 5.636 5.636m12.728 12.728L5.636 5.636',
	},
	{
		name: 'Works in any language',
		desc: 'Nope finds YouTube’s menu options by their icons, not by English text — so it works on non-English YouTube just the same.',
		path: 'm10.5 21 5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 0 1 6-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 0 1-3.827-5.802m0 0a18.092 18.092 0 0 1-1.448-4.611',
	},
	{
		name: 'Clear feedback, never silent',
		desc: 'If YouTube ever changes its menu, the button flashes red instead of doing nothing — so you always know whether it worked.',
		path: 'M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0M3.124 7.5A8.969 8.969 0 0 1 5.292 3.7m13.416 0a8.969 8.969 0 0 1 2.168 3.8',
	},
	{
		name: 'Simple on/off control',
		desc: 'A toolbar popup lets you enable or disable the whole extension, set your shortcut, and toggle the Suppress channel button anytime.',
		path: 'M5.636 5.636a9 9 0 1 0 12.728 0M12 3v9',
	},
];
---

<NopeLayout>
	<!-- ░░░ Header ░░░ -->
	<header class='sticky top-0 z-50 border-b border-white/10 bg-neutral-950/80 backdrop-blur'>
		<div class='mx-auto flex max-w-6xl items-center justify-between px-6 py-4'>
			<a
				href='/nope'
				class='flex items-center gap-2.5'>
				<Mark class='size-7' />
				<span class='text-lg font-semibold tracking-tight text-white'>Nope</span>
			</a>
			<div class='flex items-center gap-3'>
				<a
					href='#how'
					class='text-sm font-medium text-neutral-300 hover:text-white max-sm:hidden'>
					How it works
				</a>
				<a
					href={STORE_URL}
					target='_blank'
					rel='noopener noreferrer'
					class='rounded-xl px-4 py-2 text-sm font-medium text-white inset-ring inset-ring-white/15 hover:inset-ring-white/30'>
					Add to Chrome
				</a>
			</div>
		</div>
	</header>

	<!-- ░░░ Hero ░░░ -->
	<section class='relative overflow-hidden'>
		<div class='bg-nope/20 pointer-events-none absolute -top-32 -right-40 size-[36rem] rounded-full blur-[140px]'></div>
		<div class='mx-auto grid max-w-6xl items-center gap-16 px-6 py-20 sm:py-28 lg:grid-cols-2'>
			<div>
				<p class='flex items-center gap-2 font-mono text-sm font-medium tracking-wide text-neutral-400 uppercase'>
					<Mark class='size-4' /> Nope
				</p>
				<h1
					class='mt-6 max-w-[15ch] text-5xl font-semibold tracking-tight text-balance text-white sm:text-6xl lg:text-7xl'>
					One-click <span class='text-nope-bright'>&ldquo;Not interested.&rdquo;</span>
				</h1>
				<p class='mt-6 max-w-[46ch] text-lg text-pretty text-neutral-400'>
					Clean up your YouTube feed without ever opening the ⋮ menu. Nope adds a one-click dismiss button to every
					video — same signal, one-third the effort.
				</p>
				<div class='mt-9 flex flex-wrap items-center gap-x-5 gap-y-3'>
					<a
						href={STORE_URL}
						target='_blank'
						rel='noopener noreferrer'
						class='bg-nope ring-nope focus-visible:outline-nope-bright inline-flex items-center gap-2 rounded-xl px-5 py-3 text-base font-semibold text-white ring-1 hover:bg-[#e60000] focus-visible:outline-2 focus-visible:outline-offset-2'>
						<svg
							class='size-5 shrink-0 stroke-white'
							viewBox='0 0 24 24'
							fill='none'
							stroke-width='1.8'
							aria-hidden='true'>
							<path
								stroke-linecap='round'
								stroke-linejoin='round'
								d='M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3'
							></path>
						</svg>
						Get Nope — free
					</a>
					<p class='text-sm text-neutral-500'>Free to use. No account, no signup.</p>
				</div>
			</div>

			<!-- popup mockup -->
			<div class='flex justify-center lg:justify-end'>
				<div class='w-full max-w-sm rounded-2xl bg-neutral-900 p-5 inset-ring inset-ring-white/10'>
					<div class='flex items-center gap-3'>
						<Mark class='size-10' />
						<div>
							<p class='font-semibold text-white'>Nope</p>
							<p class='text-sm text-neutral-400'>One-click “Not interested.”</p>
						</div>
					</div>

					<div
						class='bg-nope/10 inset-ring-nope/40 mt-5 flex items-center justify-between gap-4 rounded-xl px-4 py-3 inset-ring'>
						<div>
							<p class='text-sm font-medium text-white'>Enable dismiss buttons</p>
							<p class='text-sm text-neutral-400'>On — active on YouTube</p>
						</div>
						<span class='bg-nope flex h-6 w-11 shrink-0 items-center rounded-full px-0.5'>
							<span class='size-5 translate-x-5 rounded-full bg-white'></span>
						</span>
					</div>

					<div class='mt-3 divide-y divide-white/10 rounded-xl inset-ring inset-ring-white/10'>
						<div class='flex items-center justify-between gap-4 px-4 py-3'>
							<div>
								<p class='text-sm font-medium text-white'>Suppress channel button</p>
								<p class='text-sm text-neutral-400'>Stop a whole channel’s recommendations.</p>
							</div>
							<span class='flex h-6 w-11 shrink-0 items-center rounded-full bg-neutral-700 px-0.5'>
								<span class='size-5 rounded-full bg-neutral-300'></span>
							</span>
						</div>
						<div class='flex items-center justify-between gap-4 px-4 py-3'>
							<div>
								<p class='text-sm font-medium text-white'>Dismiss shortcut</p>
								<p class='text-sm text-neutral-400'>Press it while hovering a video.</p>
							</div>
							<Kbd />
						</div>
					</div>

					<div class='mt-5 text-center'>
						<p class='text-sm text-neutral-400'>Feed looking cleaner?</p>
						<a
							href={COFFEE_URL}
							target='_blank'
							rel='noopener'
							class='mt-3 inline-flex items-center gap-2 rounded-xl px-4 py-2 text-sm font-medium text-neutral-200 inset-ring inset-ring-white/15 hover:inset-ring-white/30'>
							<svg
								class='size-4 shrink-0 stroke-neutral-300'
								viewBox='0 0 24 24'
								fill='none'
								stroke-width='1.5'
								aria-hidden='true'>
								<path
									stroke-linecap='round'
									stroke-linejoin='round'
									d='M16.5 9.75A3.75 3.75 0 0 1 12.75 6h-9A.75.75 0 0 0 3 6.75v6.75a4.5 4.5 0 0 0 4.5 4.5h3a4.5 4.5 0 0 0 4.5-4.5m1.5-3.75h1.125a2.625 2.625 0 0 1 0 5.25H16.5m-13.5 7.5h13.5'
								></path>
							</svg>
							Buy me a coffee
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ░░░ The chore / the fix ░░░ -->
	<section class='border-t border-white/10 py-20 sm:py-28'>
		<div class='mx-auto max-w-6xl px-6'>
			<p class='font-mono text-sm font-medium tracking-wide text-neutral-400 uppercase'>The chore</p>
			<h2 class='mt-4 max-w-[24ch] text-3xl font-semibold tracking-tight text-balance text-white sm:text-4xl'>
				Three clicks to say “no thanks.” You do it dozens of times a day.
			</h2>
			<p class='mt-5 max-w-[60ch] text-lg text-pretty text-neutral-400'>
				YouTube already lets you train your feed — it just buries the option. Nope pulls that exact action up to a
				single click on the thumbnail.
			</p>

			<div class='mt-12 grid gap-6 md:grid-cols-2'>
				<div class='rounded-2xl bg-neutral-900 p-8 inset-ring inset-ring-white/10'>
					<p class='font-mono text-sm tracking-wide text-neutral-500 uppercase'>Without Nope</p>
					<ol
						role='list'
						class='mt-6 space-y-4'>
						<li class='flex gap-4'>
							<span
								class='flex size-7 shrink-0 items-center justify-center rounded-full bg-neutral-800 font-mono text-sm text-neutral-400 tabular-nums'
								>1</span
							>
							<p class='text-base text-neutral-300'>Hover the video and hunt for the ⋮ overflow menu.</p>
						</li>
						<li class='flex gap-4'>
							<span
								class='flex size-7 shrink-0 items-center justify-center rounded-full bg-neutral-800 font-mono text-sm text-neutral-400 tabular-nums'
								>2</span
							>
							<p class='text-base text-neutral-300'>Open it and read down the list of options.</p>
						</li>
						<li class='flex gap-4'>
							<span
								class='flex size-7 shrink-0 items-center justify-center rounded-full bg-neutral-800 font-mono text-sm text-neutral-400 tabular-nums'
								>3</span
							>
							<p class='text-base text-neutral-300'>Find “Not interested” and finally click it.</p>
						</li>
					</ol>
				</div>

				<div class='bg-nope/10 inset-ring-nope/40 relative rounded-2xl p-8 inset-ring'>
					<p class='text-nope-bright font-mono text-sm tracking-wide uppercase'>With Nope</p>
					<div class='mt-6 flex items-center gap-4'>
						<span
							class='flex size-12 shrink-0 items-center justify-center rounded-full bg-neutral-950/80 shadow-lg ring-1 ring-white/15'>
							<svg
								class='size-5 stroke-white'
								viewBox='0 0 24 24'
								fill='none'
								stroke-width='2'
								aria-hidden='true'>
								<path
									stroke-linecap='round'
									stroke-linejoin='round'
									d='M6 18 18 6M6 6l12 12'
								></path>
							</svg>
						</span>
						<p class='text-xl font-medium text-white'>Click the X. The video’s gone.</p>
					</div>
					<p class='mt-6 max-w-[46ch] text-base text-pretty text-neutral-300'>
						Identical to doing it by hand — same signal, same effect on your recommendations. Just one click instead of
						three.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ░░░ Feature: one-click dismiss ░░░ -->
	<section class='border-t border-white/10 py-20 sm:py-28'>
		<div class='mx-auto grid max-w-6xl items-center gap-12 px-6 lg:grid-cols-2 lg:gap-16'>
			<div>
				<p class='font-mono text-sm font-medium tracking-wide text-neutral-400 uppercase'>Dismiss a video</p>
				<h2 class='mt-4 text-4xl font-semibold tracking-tight text-balance text-white sm:text-5xl'>One click. Gone.</h2>
				<p class='mt-6 max-w-[44ch] text-lg text-pretty text-neutral-400'>
					A dismiss button appears on every video card. Tap it and that recommendation disappears — Nope drives
					YouTube’s own “Not interested” action behind the scenes.
				</p>
				<p class='mt-4 max-w-[44ch] text-base text-pretty text-neutral-500'>
					Works on the Home feed, the Subscriptions feed, and channel “Videos” tabs.
				</p>
			</div>
			<BrowserFeed mode='dismiss' />
		</div>
	</section>

	<!-- ░░░ Feature: suppress channel ░░░ -->
	<section class='border-t border-white/10 py-20 sm:py-28'>
		<div class='mx-auto grid max-w-6xl items-center gap-12 px-6 lg:grid-cols-2 lg:gap-16'>
			<div class='lg:order-2'>
				<p class='font-mono text-sm font-medium tracking-wide text-neutral-400 uppercase'>Suppress a channel</p>
				<h2 class='mt-4 text-4xl font-semibold tracking-tight text-balance text-white sm:text-5xl'>
					Mute a whole channel for good.
				</h2>
				<p class='mt-6 max-w-[44ch] text-lg text-pretty text-neutral-400'>
					Opt in to a second button that stops an entire channel’s recommendations — it triggers YouTube’s native “Don’t
					recommend channel.”
				</p>
				<p class='mt-4 max-w-[44ch] text-base text-pretty text-neutral-500'>
					Off by default, because it’s hard to undo. When it’s on, it asks for a confirming second click — so you can’t
					wipe a channel by accident.
				</p>
			</div>
			<BrowserFeed
				mode='suppress'
				class='lg:order-1'
			/>
		</div>
	</section>

	<!-- ░░░ Feature grid (all six) ░░░ -->
	<section class='border-t border-white/10 py-20 sm:py-28'>
		<div class='mx-auto max-w-6xl px-6'>
			<p class='font-mono text-sm font-medium tracking-wide text-neutral-400 uppercase'>Everything it does</p>
			<h2 class='mt-4 max-w-[20ch] text-3xl font-semibold tracking-tight text-balance text-white sm:text-4xl'>
				Small extension. No surprises.
			</h2>
			<dl class='mt-14 grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3'>
				{
					features.map((feature) => (
						<div>
							<svg
								class='stroke-nope-bright size-6'
								viewBox='0 0 24 24'
								fill='none'
								stroke-width='1.5'
								aria-hidden='true'>
								<path
									stroke-linecap='round'
									stroke-linejoin='round'
									d={feature.path}
								/>
							</svg>
							<dt class='mt-4 text-base font-semibold text-white'>{feature.name}</dt>
							<dd class='mt-2 max-w-[42ch] text-base text-pretty text-neutral-400'>{feature.desc}</dd>
						</div>
					))
				}
			</dl>
		</div>
	</section>

	<!-- ░░░ Privacy ░░░ -->
	<section class='border-t border-white/10 py-20 sm:py-28'>
		<div class='mx-auto grid max-w-6xl items-start gap-12 px-6 lg:grid-cols-2 lg:gap-16'>
			<div>
				<p class='font-mono text-sm font-medium tracking-wide text-neutral-400 uppercase'>Privacy</p>
				<h2 class='mt-4 text-4xl font-semibold tracking-tight text-balance text-white sm:text-5xl'>
					Fast to use. Nothing to trust us with.
				</h2>
				<p class='mt-6 max-w-[48ch] text-lg text-pretty text-neutral-400'>
					Nope asks for a single permission and collects nothing. There’s no account, no analytics, and the extension
					makes no network requests of its own. The service worker is intentionally empty — there’s literally nothing
					phoning home.
				</p>

				<ul
					role='list'
					class='mt-10 space-y-5'>
					<li class='flex items-start gap-3'>
						<svg
							class='size-6 shrink-0 stroke-emerald-400'
							viewBox='0 0 24 24'
							fill='none'
							stroke-width='1.8'
							aria-hidden='true'>
							<path
								stroke-linecap='round'
								stroke-linejoin='round'
								d='m4.5 12.75 6 6 9-13.5'
							></path>
						</svg>
						<p class='text-base text-neutral-200'>
							<span class='font-medium text-white'>One permission: “storage.”</span> Used only to remember your own settings
							— on/off, your shortcut, and the suppress toggle.
						</p>
					</li>
					<li class='flex items-start gap-3'>
						<svg
							class='size-6 shrink-0 stroke-neutral-600'
							viewBox='0 0 24 24'
							fill='none'
							stroke-width='1.8'
							aria-hidden='true'>
							<path
								stroke-linecap='round'
								stroke-linejoin='round'
								d='M6 18 18 6M6 6l12 12'
							></path>
						</svg>
						<p class='text-base text-neutral-400'>No access to your history, your tabs, or your browsing activity.</p>
					</li>
					<li class='flex items-start gap-3'>
						<svg
							class='size-6 shrink-0 stroke-neutral-600'
							viewBox='0 0 24 24'
							fill='none'
							stroke-width='1.8'
							aria-hidden='true'>
							<path
								stroke-linecap='round'
								stroke-linejoin='round'
								d='M6 18 18 6M6 6l12 12'
							></path>
						</svg>
						<p class='text-base text-neutral-400'>No analytics, no tracking, nothing collected, nothing sold.</p>
					</li>
					<li class='flex items-start gap-3'>
						<svg
							class='size-6 shrink-0 stroke-neutral-600'
							viewBox='0 0 24 24'
							fill='none'
							stroke-width='1.8'
							aria-hidden='true'>
							<path
								stroke-linecap='round'
								stroke-linejoin='round'
								d='M6 18 18 6M6 6l12 12'
							></path>
						</svg>
						<p class='text-base text-neutral-400'>
							Runs only on youtube.com. Everything happens locally in your browser.
						</p>
					</li>
				</ul>

				<p class='mt-8'>
					<a
						href='/nope/privacy'
						class='text-sm font-medium text-neutral-300 underline decoration-white/30 underline-offset-4 hover:text-white'>
						Read the full privacy policy
					</a>
				</p>
			</div>

			<!-- shortcut + storage card -->
			<div class='rounded-2xl bg-neutral-900 p-6 inset-ring inset-ring-white/10'>
				<div class='flex items-center justify-between gap-4'>
					<div>
						<p class='font-medium text-white'>Dismiss shortcut</p>
						<p class='text-sm text-neutral-400'>Hover a video, tap to dismiss.</p>
					</div>
					<Kbd />
				</div>
				<hr class='my-6 border-white/10' />
				<dl class='space-y-6'>
					<div class='flex items-start gap-3'>
						<svg
							class='stroke-nope-bright size-6 shrink-0'
							viewBox='0 0 24 24'
							fill='none'
							stroke-width='1.5'
							aria-hidden='true'>
							<path
								stroke-linecap='round'
								stroke-linejoin='round'
								d='M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z'
							></path>
						</svg>
						<div>
							<dt class='text-base font-medium text-white'>Storage</dt>
							<dd class='mt-1 text-sm text-neutral-400'>Saves only your settings, synced by your browser.</dd>
						</div>
					</div>
					<div class='flex items-start gap-3'>
						<svg
							class='size-6 shrink-0 stroke-neutral-400'
							viewBox='0 0 24 24'
							fill='none'
							stroke-width='1.5'
							aria-hidden='true'>
							<path
								stroke-linecap='round'
								stroke-linejoin='round'
								d='M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88'
							></path>
						</svg>
						<div>
							<dt class='text-base font-medium text-white'>No history, no tracking, no account</dt>
							<dd class='mt-1 text-sm text-neutral-400'>It never reads your browsing or who you are.</dd>
						</div>
					</div>
				</dl>
			</div>
		</div>
	</section>

	<!-- ░░░ How it works ░░░ -->
	<section
		id='how'
		class='border-t border-white/10 py-20 sm:py-28'>
		<div class='mx-auto max-w-6xl px-6'>
			<p class='font-mono text-sm font-medium tracking-wide text-neutral-400 uppercase'>How it works</p>
			<h2 class='mt-4 max-w-[20ch] text-3xl font-semibold tracking-tight text-balance text-white sm:text-4xl'>
				Up and running in under a minute.
			</h2>
			<ol
				role='list'
				class='mt-14 grid gap-8 md:grid-cols-3'>
				<li class='rounded-2xl bg-neutral-900 p-8 inset-ring inset-ring-white/10'>
					<span class='text-nope-bright font-mono text-sm tabular-nums'>01</span>
					<h3 class='mt-4 text-lg font-semibold text-white'>Install it</h3>
					<p class='mt-2 text-base text-pretty text-neutral-400'>
						Add Nope from the Chrome Web Store. No account, no signup.
