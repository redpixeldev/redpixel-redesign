---
import NopeLayout from '@layouts/NopeLayout.astro';
import Mark from '@components/nope/Mark.astro';

const COFFEE_URL = 'https://buymeacoffee.com/vivgui';

const sections = [
	{
		title: 'Data we collect',
		body: 'None. Nope does not collect, store, transmit, or sell any personal information or browsing data. It contains no analytics, no tracking, and makes no network requests of its own.',
	},
	{
		title: 'Settings stored on your device',
		body: 'Nope saves your own preferences using the browser’s built-in storage (chrome.storage.sync): whether the extension is enabled, your optional keyboard shortcut, and whether the optional “Suppress channel” button is shown. This data stays in your browser (and, if you are signed into your browser, syncs across your own devices through the browser vendor’s sync service). It is never sent to us or to any third party. We cannot see it.',
	},
	{
		title: 'Where Nope runs',
		body: 'Nope runs only on YouTube pages (*.youtube.com). On those pages it adds its button to feed video thumbnails and activates YouTube’s own built-in “Not interested” and “Don’t recommend channel” menu options on your behalf. It does not read, record, or transmit the contents of the pages you visit.',
	},
	{
		title: 'Third parties',
		body: 'Nope does not share data with any third party, because it does not collect any data to share.',
	},
	{
		title: 'Changes to this policy',
		body: 'If this policy changes, the updated version will be posted at this URL with a new “Last updated” date.',
	},
];
---

<NopeLayout
	title='Privacy Policy — Nope'
	description='Privacy policy for Nope, the one-click “Not interested” helper for YouTube. Nope collects nothing and requests a single storage permission.'>
	<!-- Header -->
	<header class='border-b border-white/10'>
		<div class='mx-auto flex max-w-6xl items-center justify-between px-6 py-4'>
			<a
				href='/nope'
				class='flex items-center gap-2.5'>
				<Mark class='size-7' />
				<span class='text-lg font-semibold tracking-tight text-white'>Nope</span>
			</a>
			<a
				href='/nope'
				class='text-sm font-medium text-neutral-300 hover:text-white'>
				← Back to Nope
			</a>
		</div>
	</header>

	<main class='mx-auto max-w-3xl px-6 py-16 sm:py-24'>
		<p class='font-mono text-sm font-medium tracking-wide text-neutral-400 uppercase'>Privacy Policy</p>
		<h1 class='mt-4 text-4xl font-semibold tracking-tight text-balance text-white sm:text-5xl'>
			Nope — YouTube “Not interested” helper
		</h1>
		<p class='mt-4 text-sm text-neutral-500'>Last updated: June 20, 2026</p>

		<p class='mt-8 text-lg text-pretty text-neutral-300'>
			Nope is a browser extension that adds a one-click “Not interested” button to your YouTube feed. This policy
			explains what data the extension does and does not handle.
		</p>

		<div class='mt-12 space-y-10'>
			{
				sections.map((section) => (
					<section>
						<h2 class='text-xl font-semibold tracking-tight text-white'>{section.title}</h2>
						<p class='mt-3 text-base text-pretty text-neutral-400'>{section.body}</p>
					</section>
				))
			}

			<section>
				<h2 class='text-xl font-semibold tracking-tight text-white'>Contact</h2>
				<p class='mt-3 text-base text-pretty text-neutral-400'>
					Questions about this policy or the extension:
					<a
						href='mailto:support@redpixel.io'
						class='font-medium text-neutral-200 underline decoration-white/30 underline-offset-4 hover:text-white'>
						support@redpixel.io
					</a>
				</p>
			</section>
		</div>
	</main>

	<!-- Footer -->
	<footer class='border-t border-white/10 py-12'>
		<div class='mx-auto flex max-w-6xl flex-col gap-8 px-6 sm:flex-row sm:items-center sm:justify-between'>
			<div>
				<a
					href='/nope'
					class='flex items-center gap-2.5'>
					<Mark class='size-6' />
					<span class='text-base font-semibold tracking-tight text-white'>Nope</span>
				</a>
				<p class='mt-3 text-sm text-neutral-500'>One-click “Not interested” for YouTube. A Red Pixel project.</p>
			</div>
			<nav class='flex flex-wrap items-center gap-x-6 gap-y-3'>
				<a
					href='mailto:support@redpixel.io'
					class='text-sm font-normal text-neutral-400 hover:text-white'>
					support@redpixel.io
				</a>
				<a
					href={COFFEE_URL}
					target='_blank'
					rel='noopener'
					class='text-sm font-normal text-neutral-400 hover:text-white'>
					Buy me a coffee
				</a>
				<a
					href='/nope/privacy'
					class='text-sm font-normal text-neutral-400 hover:text-white'>
					Privacy policy
				</a>
			</nav>
		</div>
		<div class='mx-auto mt-8 max-w-6xl px-6'>
			<p class='text-sm text-neutral-600'>© {new Date().getFullYear()} Red Pixel. Free to use, no account required.</p>
		</div>
	</footer>
</NopeLayout>
